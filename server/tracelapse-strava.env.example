# Copy to /etc/tracelapse-strava.env (root-owned, chmod 600) and fill in.
# Create the Strava API app at https://www.strava.com/settings/api
# and set its "Authorization Callback Domain" to your app's host (no scheme),
# e.g. tracelapse.tbrun.dev
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
REDIRECT_URI=https://tracelapse.tbrun.dev/api/callback
APP_ORIGIN=https://tracelapse.tbrun.dev
PORT=8030
